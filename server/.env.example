# Copy to .env (server/.env) and fill in. NEVER commit the real .env.
# MongoDB Atlas connection string. Password stays here, not in code or git.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Database name (created automatically on first write).
MONGODB_DB=cdc
# Shared secret the .ps1 / loader must send as x-ingest-token. Leave empty to disable auth (dev only).
INGEST_TOKEN=change-me
# Port the API listens on (Render sets this automatically).
PORT=3000
